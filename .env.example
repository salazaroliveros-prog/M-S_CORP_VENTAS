# Ejemplo de archivo .env para tu proyecto

# URL de conexión a la base de datos PostgreSQL (obligatorio)
DATABASE_URL="postgresql://usuario:contraseña@host:puerto/nombre_db?sslmode=require"

# (Opcional) Variables de conexión individuales para clientes o herramientas
PGHOST=host
PGDATABASE=nombre_db
PGUSER=usuario
PGPASSWORD=contraseña
PGPORT=5432

# Clave para Gemini AI (solo si usas Gemini)
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# URL pública de la app (opcional, útil para callbacks)
APP_URL="MY_APP_URL"

# Entorno de ejecución (recomendado)
NODE_ENV=production
